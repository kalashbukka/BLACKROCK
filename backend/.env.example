# ---------- Backend configuration (example) ----------
# Copy this to .env and fill real values locally. DO NOT commit .env.

# Secret used to sign JWT tokens.
SECRET_KEY=change-this-to-a-long-random-secret

# How long a login token stays valid (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Gemini API key (keep ONLY in the backend, rotate if compromised)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-3.5-flash

NVIDIA_API_KEY=YOUR_NVIDIA_API_KEY_HERE
NVIDIA_MODEL=google/gemma-4-31b-it

GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3-3.70b-versatile

# Frontend origin allowed by CORS (Vite dev server)
FRONTEND_ORIGIN=http://localhost:5173

# SQLite database file (use an absolute path or local path)
DATABASE_URL=sqlite:///./medimind.db
